# --- LLM gateway: the ONLY LLM credential needed ---
# Chat AND embeddings route through Vercel AI Gateway with one vck_ key;
# model names are provider-prefixed (openai/...).
LLM_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
LLM_GATEWAY_API_KEY=
OPENAI_CHAT_MODEL=openai/gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=openai/text-embedding-3-small

# Fallback only if you skip the gateway entirely (leave LLM_GATEWAY_* unset):
# OPENAI_API_KEY=

# --- Tools ---
TAVILY_API_KEY=

# --- LangSmith tracing / eval datasets ---
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=beedoula

# --- RAG ---
RAG_DATA_DIR=data
