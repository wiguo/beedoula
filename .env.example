# --- LLM gateway (hard requirement) ---
# Chat goes through Vercel AI Gateway; model names are provider-prefixed.
LLM_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
LLM_GATEWAY_API_KEY=
OPENAI_CHAT_MODEL=openai/gpt-5.4-mini

# --- OpenAI direct (embeddings) ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Tools ---
TAVILY_API_KEY=

# --- LangSmith tracing / eval datasets ---
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=beedoula

# --- RAG ---
RAG_DATA_DIR=data
